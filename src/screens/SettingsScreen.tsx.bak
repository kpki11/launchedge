// src/screens/SettingsScreen.tsx
// Tagline: "Your data lives where you want it."
import React, { useState } from 'react';
import {
  View, Text, StyleSheet, ScrollView, TouchableOpacity,
  Switch, Alert, Linking, Image, Share, TextInput,
} from 'react-native';
import { SafeAreaView } from 'react-native-safe-area-context';
import { Ionicons } from '@expo/vector-icons';
import { Theme, Colors } from '../theme/colors';
import { Typography, Spacing, Radius } from '../theme/typography';
import { useBusinessStore } from '../store/useBusinessStore';
import { useApprovalStore } from '../store/useApprovalStore';
// Google Drive OAuth: coming in a future release
import { updateBusinessJoinCode, updateBusinessName } from '../services/database';

export default function SettingsScreen({ navigation }: any) {
  const { activeBusiness, setBusiness, logout, clearAllData } = useBusinessStore();
  const { pendingCount } = useApprovalStore();
  const [requireApprovalNew, setRequireApprovalNew] = useState(false);
  const [requireApprovalEdit, setRequireApprovalEdit] = useState(false);
  const [editingName, setEditingName] = useState(false);
  const [nameInput, setNameInput] = useState('');

  const isCloudMode = activeBusiness?.storageMode === 'googleDrive';
  const handleSaveName = async () => {
    const trimmed = nameInput.trim();
    if (!trimmed) { Alert.alert('Required', 'Business name cannot be empty.'); return; }
    if (!activeBusiness) return;
    try {
      await updateBusinessName(activeBusiness.id, trimmed);
      setBusiness({ ...activeBusiness, name: trimmed });
      setEditingName(false);
    } catch (e) {
      Alert.alert('Error', 'Could not save name. Please try again.');
    }
  };

  const handleGenerateJoinCode = async () => {
    if (!activeBusiness) return;
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
    const code = Array.from({ length: 6 }, () => chars[Math.floor(Math.random() * chars.length)]).join('');
    try {
      await updateBusinessJoinCode(activeBusiness.id, code);
      setBusiness({ ...activeBusiness, joinCode: code });
    } catch (e) {
      Alert.alert('Error', 'Could not generate code. Please try again.');
    }
  };


  const handleConnectDrive = () => {
    Alert.alert(
      'Coming Soon',
      'Google Drive sync will be available in the next update. Your data is safely stored on this device.',
      [{ text: 'Got it' }]
    );
  };

  const handleDisconnectDrive = () => {
    Alert.alert('Disconnect Google Drive', 'Your data will remain on device. No data will be deleted.', [
      { text: 'Cancel', style: 'cancel' },
      { text: 'Disconnect', style: 'destructive', onPress: () => {
        if (activeBusiness) setBusiness({ ...activeBusiness, storageMode: 'local', googleEmail: undefined });
      }},
    ]);
  };

  const handleLogout = () => {
    Alert.alert(
      'Log out',
      'You will return to the welcome screen. Your data stays on this device.',
      [
        { text: 'Cancel', style: 'cancel' },
        { text: 'Log out', style: 'destructive', onPress: async () => { await logout(); } },
      ]
    );
  };

  const handleClearData = () => {
    Alert.alert(
      'Clear all data',
      'This permanently deletes ALL your business data and settings. Cannot be undone.',
      [
        { text: 'Cancel', style: 'cancel' },
        { text: 'Delete everything', style: 'destructive', onPress: () => {
          Alert.alert(
            'Absolutely sure?',
            'Every table, record, and setting will be gone forever.',
            [
              { text: 'Go back', style: 'cancel' },
              { text: 'Yes, delete everything', style: 'destructive', onPress: async () => { await clearAllData(); } },
            ]
          );
        }},
      ]
    );
  };

  return (
    <SafeAreaView style={styles.safe}>
      {/* Top Hero Image */}
      <Image
        source={require('../../assets/images/hero_brush_pot.jpeg')}
        style={styles.heroImage}
        resizeMode="cover"
      />

      <ScrollView showsVerticalScrollIndicator={false} contentContainerStyle={styles.content}>
        {/* Page Header */}
        <View style={styles.pageHeader}>
          <Text style={styles.pageTitle}>Settings</Text>
          <Text style={styles.pageSub}>Your data lives where you want it.</Text>
        </View>

        {/* Approvals Quick Access */}
        <TouchableOpacity
          style={styles.approvalLink}
          onPress={() => navigation.navigate('Approvals')}
        >
          <View style={styles.approvalLeft}>
            <View style={styles.approvalIcon}>
              <Ionicons name="shield-checkmark-outline" size={20} color={Theme.primary} />
            </View>
            <View>
              <Text style={styles.approvalLinkTitle}>Approvals Queue</Text>
              <Text style={styles.approvalLinkSub}>
                {pendingCount > 0 ? `${pendingCount} pending approval${pendingCount > 1 ? 's' : ''}` : 'No pending approvals'}
              </Text>
            </View>
          </View>
          <View style={styles.approvalRight}>
            {pendingCount > 0 && (
              <View style={styles.badge}>
                <Text style={styles.badgeText}>{pendingCount}</Text>
              </View>
            )}
            <Ionicons name="chevron-forward" size={18} color={Theme.textDim} />
          </View>
        </TouchableOpacity>


        {/* Section: Tools */}
        <SectionHeader title="Tools" />
        <View style={styles.card}>
          <TouchableOpacity style={styles.row} onPress={() => navigation.navigate('AdminBuilder')} activeOpacity={0.75}>
            <View style={styles.rowLeft}>
              <View style={styles.rowIcon}><Ionicons name="construct-outline" size={18} color={Theme.primary} /></View>
              <View>
                <Text style={styles.rowLabel}>Admin Builder</Text>
                <Text style={styles.rowSub}>Manage tables, fields and analytics</Text>
              </View>
            </View>
            <Ionicons name="chevron-forward" size={18} color={Theme.textDim} />
          </TouchableOpacity>
          <View style={styles.divider} />
          <TouchableOpacity style={styles.row} onPress={() => navigation.navigate('TemplateLibrary')} activeOpacity={0.75}>
            <View style={styles.rowLeft}>
              <View style={styles.rowIcon}><Ionicons name="library-outline" size={18} color={Theme.primary} /></View>
              <View>
                <Text style={styles.rowLabel}>Template Library</Text>
                <Text style={styles.rowSub}>29 ready-made table structures</Text>
              </View>
            </View>
            <Ionicons name="chevron-forward" size={18} color={Theme.textDim} />
          </TouchableOpacity>
        </View>
        {/* Section: Business Profile */}
        <SectionHeader title="Business Profile" />
        <View style={styles.card}>
          {/* Business Name Ś inline editable */}
          {editingName ? (
            <View style={styles.inlineEditRow}>
              <View style={styles.rowIcon}><Ionicons name="business-outline" size={18} color={Theme.primary} /></View>
              <TextInput
                style={styles.inlineInput}
                value={nameInput}
                onChangeText={setNameInput}
                autoFocus
                returnKeyType="done"
                onSubmitEditing={handleSaveName}
                maxLength={60}
              />
              <TouchableOpacity onPress={handleSaveName} style={styles.inlineSave}>
                <Ionicons name="checkmark" size={18} color={Theme.primary} />
              </TouchableOpacity>
              <TouchableOpacity onPress={() => setEditingName(false)} style={styles.inlineCancel}>
                <Ionicons name="close" size={18} color={Theme.textDim} />
              </TouchableOpacity>
            </View>
          ) : (
            <SettingsRow
              icon="business-outline"
              label="Business Name"
              value={activeBusiness?.name || 'Not set'}
              onPress={() => { setNameInput(activeBusiness?.name || ''); setEditingName(true); }}
            />
          )}
          <SettingsRow
            icon="grid-outline"
            label="Business Type"
            value={activeBusiness?.type || 'Not set'}
            onPress={() => Alert.alert('Business Type', 'To change your business type, clear all data and re-onboard. This protects your existing table structures.')}
          />
        </View>


        {/* Section: Team & Join Code */}
        <SectionHeader title="Team" />
        <View style={styles.card}>
          {activeBusiness?.joinCode ? (
            <>
              <View style={styles.joinCodeRow}>
                <View style={styles.joinCodeLeft}>
                  <Text style={styles.joinCodeLabel}>Your Join Code</Text>
                  <Text style={styles.joinCode}>{activeBusiness.joinCode}</Text>
                  <Text style={styles.joinCodeSub}>Share with your team Ś they enter this on first launch</Text>
                </View>
                <TouchableOpacity
                  style={styles.copyBtn}
                  onPress={() => {
                    Share.share({ message: 'LaunchEdge Join Code: ' + (activeBusiness.joinCode ?? ''), title: 'LaunchEdge Join Code' });
                  }}
                  activeOpacity={0.7}
                >
                  <Ionicons name="share-social-outline" size={18} color={Theme.primary} />
                  <Text style={styles.copyBtnText}>Share</Text>
                </TouchableOpacity>
              </View>
            </>
          ) : (
            <View style={styles.joinCodeGenerateRow}>
              <View style={{ flex: 1 }}>
                <Text style={styles.joinCodeLabel}>No Join Code Yet</Text>
                <Text style={styles.joinCodeSub}>Generate a code to let teammates join your business.</Text>
              </View>
              <TouchableOpacity
                style={styles.generateBtn}
                onPress={handleGenerateJoinCode}
                activeOpacity={0.75}
              >
                <Ionicons name="key-outline" size={16} color={Theme.primary} />
                <Text style={styles.generateBtnText}>Generate Code</Text>
              </TouchableOpacity>
            </View>
          )}
        </View>
        {/* Section: Storage & Sync */}
        <SectionHeader title="Storage & Sync" />
        <View style={styles.card}>
          <View style={styles.storageStatus}>
            <View style={styles.storageLeft}>
              <Ionicons
                name={isCloudMode ? 'cloud-done-outline' : 'phone-portrait-outline'}
                size={22}
                color={isCloudMode ? Colors.success : Colors.dim}
              />
              <View>
                <Text style={styles.storageMode}>
                  {isCloudMode ? 'Google Drive Sync' : 'Local Storage'}
                </Text>
                <Text style={styles.storageEmail}>
                  {isCloudMode
                    ? activeBusiness?.googleEmail || 'Connected'
                    : 'Data stored on this device only'}
                </Text>
              </View>
            </View>
          </View>
          {isCloudMode ? (
            <TouchableOpacity style={styles.dangerRow} onPress={handleDisconnectDrive}>
              <Ionicons name="cloud-offline-outline" size={18} color={Theme.danger} />
              <Text style={styles.dangerText}>Disconnect Google Drive</Text>
            </TouchableOpacity>
          ) : (
            <TouchableOpacity
              style={styles.driveBtn}
              onPress={handleConnectDrive}
            >
              <Ionicons name="logo-google" size={18} color={Theme.primary} />
              <Text style={styles.driveBtnText}>
                {'Connect Google Drive'}
              </Text>
            </TouchableOpacity>
          )}
        </View>

        {/* Section: Approvals */}
        <SectionHeader title="Approval Settings" />
        <View style={styles.card}>
          <View style={styles.toggleRow}>
            <View style={{ flex: 1 }}>
              <Text style={styles.toggleLabel}>Require approval for new records</Text>
              <Text style={styles.toggleSub}>New entries go to queue before being saved</Text>
            </View>
            <Switch
              value={requireApprovalNew}
              onValueChange={setRequireApprovalNew}
              trackColor={{ false: Theme.border, true: Theme.primary }}
              thumbColor={Colors.ivory}
            />
          </View>
          <View style={[styles.toggleRow, { borderTopWidth: 1, borderTopColor: Theme.border }]}>
            <View style={{ flex: 1 }}>
              <Text style={styles.toggleLabel}>Require approval for edits</Text>
              <Text style={styles.toggleSub}>Changes require your sign-off</Text>
            </View>
            <Switch
              value={requireApprovalEdit}
              onValueChange={setRequireApprovalEdit}
              trackColor={{ false: Theme.border, true: Theme.primary }}
              thumbColor={Colors.ivory}
            />
          </View>
        </View>

        {/* Section: Data Management */}
        <SectionHeader title="Data" />
        <View style={styles.card}>
          <SettingsRow
            icon="download-outline"
            label="Export All Data"
            value="Download as CSV"
            onPress={() => Alert.alert('Export', 'CSV export coming soon.')}
          />
          <SettingsRow
            icon="cloud-upload-outline"
            label="Import from Backup"
            value=""
            onPress={() => Alert.alert('Import', 'Backup import coming soon.')}
          />
            <TouchableOpacity style={styles.dangerRow} onPress={handleLogout}>
              <Ionicons name="log-out-outline" size={18} color={Theme.danger} />
              <Text style={styles.dangerText}>Log out / switch business</Text>
            </TouchableOpacity>
          <TouchableOpacity style={styles.dangerRow} onPress={handleClearData}>
            <Ionicons name="trash-outline" size={18} color={Theme.danger} />
            <Text style={styles.dangerText}>Clear all data</Text>
          </TouchableOpacity>
        </View>

        {/* Section: About */}
        <SectionHeader title="About" />
        <View style={styles.card}>
          <SettingsRow icon="information-circle-outline" label="Version" value="1.0.0" />
          <SettingsRow
            icon="shield-outline"
            label="Privacy Policy"
            value=""
            onPress={() => Alert.alert('Privacy', 'Privacy policy coming soon.')}
          />
          <SettingsRow
            icon="mail-outline"
            label="Contact Support"
            value=""
            onPress={() => Alert.alert('Support', 'support@launchedgelabs.com')}
          />
        </View>

        <Text style={styles.footer}>LaunchEdge Labs ’┐Į 2026 ’┐Į Local-first MSME operations</Text>
      </ScrollView>
    </SafeAreaView>
  );
}

function SectionHeader({ title }: { title: string }) {
  return (
    <Text style={sectionStyles.title}>{title.toUpperCase()}</Text>
  );
}

function SettingsRow({ icon, label, value, onPress }: {
  icon: string; label: string; value?: string; onPress?: () => void;
}) {
  const Row = onPress ? TouchableOpacity : View;
  return (
    <Row style={rowStyles.row} onPress={onPress} activeOpacity={0.7}>
      <Ionicons name={icon as any} size={18} color={Theme.primary} />
      <View style={rowStyles.middle}>
        <Text style={rowStyles.label}>{label}</Text>
        {value ? <Text style={rowStyles.value}>{value}</Text> : null}
      </View>
      {onPress && <Ionicons name="chevron-forward" size={16} color={Theme.textDim} />}
    </Row>
  );
}

const sectionStyles = StyleSheet.create({
  title: { ...Typography.labelCaps, color: Theme.textDim, paddingHorizontal: Spacing.lg, marginTop: Spacing.xl, marginBottom: Spacing.xs },
});

const rowStyles = StyleSheet.create({
  row: {
    flexDirection: 'row', alignItems: 'center', gap: Spacing.md,
    paddingVertical: Spacing.md,
    borderBottomWidth: 1, borderBottomColor: Theme.border,
  },
  middle: { flex: 1 },
  label: { ...Typography.bodyM, color: Theme.textPrimary },
  value: { ...Typography.bodyS, color: Theme.textSecondary, marginTop: 2 },
});

const styles = StyleSheet.create({
  safe: { flex: 1, backgroundColor: Theme.background },
  heroOverlay: { ...StyleSheet.absoluteFillObject, backgroundColor: 'rgba(12,11,9,0.52)' },
  heroContent: { paddingHorizontal: Spacing.xl, paddingBottom: Spacing.xl, paddingTop: Spacing.lg },
  heroTitle:  { ...Typography.headingL, color: Colors.ivory },
  heroSub:    { ...Typography.bodyS, color: 'rgba(250,248,243,0.75)' },
  heroImage: { height: 120, width: '100%' },
  content: { paddingBottom: 100 },
  pageHeader: {
    paddingHorizontal: Spacing.lg,
    paddingTop: Spacing.md,
    paddingBottom: Spacing.sm,
    borderBottomWidth: 1,
    borderBottomColor: Theme.border,
  },
  pageTitle: { ...Typography.headingL, color: Theme.textPrimary },
  pageSub: { ...Typography.bodyS, color: Theme.textSecondary, marginTop: 2 },
  approvalLink: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'space-between',
    marginHorizontal: Spacing.lg,
    marginTop: Spacing.lg,
    backgroundColor: Theme.surface,
    borderRadius: Radius.lg,
    padding: Spacing.lg,
    borderWidth: 1,
    borderColor: Theme.border,
  },
  approvalLeft: { flexDirection: 'row', alignItems: 'center', gap: Spacing.md },
  approvalIcon: {
    width: 40, height: 40, borderRadius: Radius.md,
    backgroundColor: Theme.primaryLight,
    alignItems: 'center', justifyContent: 'center',
  },
  approvalLinkTitle: { ...Typography.headingS, color: Theme.textPrimary },
  approvalLinkSub: { ...Typography.bodyS, color: Theme.textSecondary, marginTop: 2 },
  approvalRight: { flexDirection: 'row', alignItems: 'center', gap: Spacing.sm },
  badge: {
    backgroundColor: Theme.danger,
    width: 22, height: 22, borderRadius: 11,
    alignItems: 'center', justifyContent: 'center',
  },
  badgeText: { ...Typography.labelCaps, color: '#fff', fontSize: 10 },
  card: {
    backgroundColor: Theme.surface,
    borderRadius: Radius.lg,
    paddingHorizontal: Spacing.lg,
    marginHorizontal: Spacing.lg,
    borderWidth: 1,
    borderColor: Theme.border,
  },
  storageStatus: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'space-between',
    paddingVertical: Spacing.md,
    borderBottomWidth: 1,
    borderBottomColor: Theme.border,
  },
  storageLeft: { flexDirection: 'row', alignItems: 'center', gap: Spacing.md },
  storageMode: { ...Typography.bodyM, color: Theme.textPrimary, fontFamily: 'DMSans_500Medium' },
  storageEmail: { ...Typography.bodyS, color: Theme.textSecondary, marginTop: 2 },
  driveBtn: {
    flexDirection: 'row',
    alignItems: 'center',
    gap: Spacing.sm,
    paddingVertical: Spacing.md,
  },
  driveBtnText: { ...Typography.bodyM, color: Theme.primary, fontFamily: 'DMSans_500Medium' },
  dangerRow: {
    flexDirection: 'row',
    alignItems: 'center',
    gap: Spacing.sm,
    paddingVertical: Spacing.md,
  },
  dangerText: { ...Typography.bodyM, color: Theme.danger },
  toggleRow: { flexDirection: 'row', alignItems: 'center', paddingVertical: Spacing.md, gap: Spacing.md },
  toggleLabel: { ...Typography.bodyM, color: Theme.textPrimary },
  toggleSub: { ...Typography.bodyS, color: Theme.textSecondary, marginTop: 2 },
  joinCodeRow: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'space-between',
    paddingVertical: 14,
    gap: 12,
  },
  joinCodeLeft: { flex: 1 },
  joinCodeLabel: { fontSize: 11, fontFamily: 'DMSans_500Medium', color: '#9a8e7e', textTransform: 'uppercase', letterSpacing: 0.6, marginBottom: 4 },
  joinCode: { fontSize: 26, fontFamily: 'DMSans_700Bold', color: '#c4963a', letterSpacing: 3, marginBottom: 4 },
  joinCodeSub: { fontSize: 12, color: '#9a8e7e', fontFamily: 'DMSans_400Regular' },
  copyBtn: { flexDirection: 'row', alignItems: 'center', gap: 6, backgroundColor: 'rgba(196,150,58,0.10)', borderRadius: 8, paddingHorizontal: 12, paddingVertical: 8 },
  copyBtnText: { fontSize: 13, color: '#c4963a', fontFamily: 'DMSans_500Medium' },
  joinCodeGenerateRow: { flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between', paddingVertical: 14, gap: 12 },
  generateBtn: { flexDirection: 'row', alignItems: 'center', gap: 6, backgroundColor: 'rgba(196,150,58,0.10)', borderRadius: 8, paddingHorizontal: 12, paddingVertical: 8 },
  generateBtnText: { fontSize: 13, color: '#c4963a', fontFamily: 'DMSans_500Medium' },
  inlineEditRow: { flexDirection: 'row', alignItems: 'center', gap: 8, paddingVertical: 10 },
  inlineInput: { flex: 1, fontSize: 15, fontFamily: 'DMSans_500Medium', color: '#2c2218', borderBottomWidth: 1, borderBottomColor: '#c4963a', paddingVertical: 4 },
  inlineSave: { width: 34, height: 34, borderRadius: 17, backgroundColor: 'rgba(196,150,58,0.15)', justifyContent: 'center', alignItems: 'center' },
  inlineCancel: { width: 34, height: 34, borderRadius: 17, backgroundColor: 'rgba(0,0,0,0.05)', justifyContent: 'center', alignItems: 'center' },
  footer: { ...Typography.bodyS, color: Theme.textDim, textAlign: 'center', marginTop: Spacing.xl, paddingHorizontal: Spacing.lg },
  row: { flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between', paddingVertical: Spacing.md },
  rowLeft: { flexDirection: 'row', alignItems: 'center', gap: Spacing.md, flex: 1 },
  rowIcon: { width: 34, height: 34, borderRadius: Radius.md, backgroundColor: 'rgba(196,150,58,0.10)', justifyContent: 'center', alignItems: 'center' },
  rowLabel: { ...Typography.bodyM, color: Theme.textPrimary, fontFamily: 'DMSans_500Medium' },
  rowSub: { ...Typography.bodyS, color: Theme.textSecondary, marginTop: 2 },
  divider: { height: 1, backgroundColor: Theme.border, marginLeft: 50 },
});













