# LaunchEdge .gitignore
# Only website files are tracked publicly.

# Node
node_modules/
npm-debug.log*

# Build outputs & APKs (hosted via GitHub Releases instead)
dist/
build/
*.apk
*.aab
*.ipa

# App source code (kept private)
android/
ios/
LaunchEdgeLabs/
*.gradle
local.properties

# Secrets
.env
.env.*
*.key
*.pem
secrets/

# Dev temp files
*.tmp
*.bak
snap.png
ss.jpg
t.png
docs/
components/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
# API keys — never commit
js/copilot.config.js
